package vehiculos;
public abstract class Vehiculo {
    private String numeroDePlaca;
    private String marca;
    private String modelo;
    private int año;
    private double costoPorDia;
    public Vehiculo(String numeroDePlaca, String marca, String modelo, int año, double 
costoPorDia) {
        this.numeroDePlaca = numeroDePlaca;
        this.marca = marca;
        this.modelo = modelo;
        this.año = año;
        this.costoPorDia = costoPorDia;
    }
    public String getNumeroDePlaca() { return numeroDePlaca; }
    public String getMarca() { return marca; }
    public String getModelo() { return modelo; }
    public int getAnio() { return añio; }
    public double getCostoPorDia() { return costoPorDia; }
    public void setNumeroDePlaca(String numeroDePlaca) { this.numeroDePlaca = 
numeroDePlaca; }
    public void setMarca(String marca) { this.marca = marca; }
    public void setModelo(String modelo) { this.modelo = modelo; }
    public void setAnio(int año) { this.año = año; }
    public void setCostoPorDia(double costoPorDia) { this.costoPorDia = costoPorDia; }
    public abstract String getTipoVehiculo();
    @Override
    public String toString() {
        return String.format("[%s] %s %s %d | Placa: %s | $%.2f/día",
                getTipoVehiculo(), marca, modelo, año, numeroDePlaca, costoPorDia);
    }
}