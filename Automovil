package vehiculos;
public class Automovil extends Vehiculo {
    private int numeroDePuertas;
    private String tipoTransmision; // "manual" o "automatica"
    public Automovil(String numeroDePlaca, String marca, String modelo, int anio,
                     double costoPorDia, int numeroDePuertas, String tipoTransmision) {
        super(numeroDePlaca, marca, modelo, anio, costoPorDia);
        this.numeroDePuertas = numeroDePuertas;
        this.tipoTransmision = tipoTransmision;
    }
    public int getNumeroDePuertas() { return numeroDePuertas; }
    public String getTipoTransmision() { return tipoTransmision; }
    public void setNumeroDePuertas(int numeroDePuertas) { this.numeroDePuertas = 
numeroDePuertas; }
    public void setTipoTransmision(String tipoTransmision) { this.tipoTransmision = 
tipoTransmision; }
    @Override
    public String getTipoVehiculo() { return "Automóvil"; }
    @Override
    public String toString() {
        return super.toString() + String.format("\n   Puertas: %d | Transmisión: %s",
                numeroDePuertas, tipoTransmision);
    }
}